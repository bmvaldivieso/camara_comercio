<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Iniciar sesión - Cámara de Comercio de Loja</title>

    <!-- Bootstrap -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      defer
    ></script>

    <style>
      body {
        background-image: url("img/fondo.jpg");
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        color: white;
      }

      .form-control::placeholder {
        color: white;
        opacity: 1;
      }

      input.form-control {
        background-color: rgba(255, 255, 255, 0.2);
        color: white;
        border: 2px solid white;
      }

      a.text-primary {
        text-decoration: none;
      }
    </style>
  </head>

  <body class="d-flex align-items-center justify-content-center min-vh-100">
    <!-- Logo en la esquina superior izquierda -->
    <img
      src="/img/logo.png"
      alt="Logo Cámara"
      style="position: absolute; top: 20px; left: 30px; height: 80px; z-index: 10;"
    />

    <div class="container">
      <div class="row justify-content-center">
        <div
          class="col-md-6 col-lg-5 p-5 rounded shadow"
          style="background-color: rgba(8, 40, 68, 0.5);"
        >
          <div class="text-center mb-2">
            <h1 class="mb-1 fw-bold">Iniciar sesión</h1>
          </div>

          <!-- Formulario de inicio de sesión -->
          <form>
            <div class="mb-3">
              <label for="email" class="form-label">Usuario</label>
              <input
                type="text"
                class="form-control rounded-pill text-white"
                id="email"
                placeholder="Correo o número de teléfono"
              />
            </div>

            <div class="mb-3">
              <label for="password" class="form-label">Contraseña</label>
              <div class="input-group">
                <input
                  type="password"
                  class="form-control rounded-start-pill text-white"
                  id="password"
                  placeholder="Ingresa tu contraseña"
                />
                <span
                  class="input-group-text rounded-end-pill border-secondary text-white"
                >
                  👁
                </span>
              </div>
            </div>

            <div class="d-flex justify-content-between mb-3">
              <div class="form-check">
                <input class="form-check-input" type="checkbox" id="remember" />
                <label class="form-check-label" for="remember">
                  Recordarme
                </label>
              </div>
              <a href="#" class="text-primary">¿Olvidaste tu contraseña?</a>
            </div>

            <button
              type="submit"
              class="btn btn-warning w-100 rounded-pill fw-bold"
            >
              Ingresar
            </button>
          </form>

          <br />
          <div class="d-flex justify-content-between mb-3">
            <div class="form-check">
              <label class="form-check-label" for="remember">
                ¿No tienes una cuenta?
              </label>
            </div>
            <a href="/register" class="text-primary">Regístrate ahora</a>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
